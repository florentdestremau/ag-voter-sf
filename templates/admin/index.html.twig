{% extends 'base.html.twig' %}

{% block title %}Sessions - Admin{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-collection"></i> Sessions de vote</h1>
    <a href="{{ path('admin_session_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nouvelle session
    </a>
</div>

{% if sessions is empty %}
    <div class="card text-center py-5">
        <div class="card-body">
            <i class="bi bi-inbox display-4 text-muted"></i>
            <p class="mt-3 text-muted">Aucune session créée pour l'instant.</p>
            <a href="{{ path('admin_session_new') }}" class="btn btn-primary">Créer une session</a>
        </div>
    </div>
{% else %}
    <div class="row g-3">
        {% for session in sessions %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title">{{ session.name }}</h5>
                            {% if session.isPending %}
                                <span class="badge bg-secondary">En attente</span>
                            {% elseif session.isActive %}
                                <span class="badge bg-success">En cours</span>
                            {% else %}
                                <span class="badge bg-dark">Terminée</span>
                            {% endif %}
                        </div>
                        <p class="card-text text-muted small">
                            <i class="bi bi-people"></i> {{ session.participants|length }} participant(s)<br>
                            <i class="bi bi-question-circle"></i> {{ session.questions|length }} question(s)<br>
                            <i class="bi bi-clock"></i> {{ session.createdAt|date('d/m/Y H:i') }}
                        </p>
                    </div>
                    <div class="card-footer">
                        <a href="{{ path('admin_session_show', {id: session.id}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-gear"></i> Gérer
                        </a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
