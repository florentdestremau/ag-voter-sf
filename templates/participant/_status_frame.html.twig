<turbo-frame id="vote-status">
    {% if session.isClosed %}
        <div class="card text-center py-5">
            <div class="card-body">
                <i class="bi bi-check-circle-fill display-3 text-success"></i>
                <h3 class="mt-3">Session terminée</h3>
                <p class="text-muted">Merci pour votre participation !</p>
            </div>
        </div>

    {% elseif session.isPending %}
        <div class="card text-center py-5">
            <div class="card-body">
                <div class="spinner-border text-primary mb-3" role="status"></div>
                <h3>Salle d'attente</h3>
                <p class="text-muted">En attente du démarrage de la session...</p>
                <p class="text-muted small">La page se met à jour automatiquement.</p>
            </div>
        </div>

    {% elseif activeQuestion %}
        {# Active question - vote or "already voted" #}
        <div class="card border-success mb-4">
            <div class="card-header bg-success text-white">
                <i class="bi bi-question-circle"></i> Question en cours
            </div>
            <div class="card-body">
                <h5 class="card-title mb-4">{{ activeQuestion.text }}</h5>

                {% if alreadyVoted %}
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-check-circle"></i> <strong>Vous avez déjà voté sur cette question.</strong>
                        <br>En attente de la fermeture de la question pour voir les résultats...
                    </div>
                {% else %}
                    <form method="post" action="{{ path('participant_submit_vote', {token: participant.token}) }}"
                          data-controller="vote-form">
                        {% for choice in activeQuestion.choices %}
                            <div class="mb-3">
                                <div class="d-grid">
                                    <button type="submit" name="choice_id" value="{{ choice.id }}"
                                            class="btn btn-outline-primary btn-lg text-start"
                                            data-vote-form-target="choiceBtn"
                                            data-choice-id="{{ choice.id }}">
                                        <i class="bi bi-circle me-2"></i> {{ choice.text }}
                                        {% if choice.allowFreeText %}
                                            <span class="badge bg-light text-dark ms-1">+ commentaire</span>
                                        {% endif %}
                                    </button>
                                </div>
                                {% if choice.allowFreeText %}
                                    <div class="mt-1 free-text-area" id="free-text-{{ choice.id }}" style="display:none">
                                        <input type="text" name="free_text" class="form-control"
                                               placeholder="Votre commentaire (optionnel)" maxlength="500">
                                    </div>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </form>
                {% endif %}
            </div>
        </div>

    {% else %}
        <div class="card text-center py-4 border-info mb-4">
            <div class="card-body">
                <i class="bi bi-hourglass-split display-4 text-info"></i>
                <h4 class="mt-3">En attente d'une question...</h4>
                <p class="text-muted">L'admin va bientôt activer une question.</p>
            </div>
        </div>
    {% endif %}

    {# Closed questions results #}
    {% if closedResults is not empty %}
        <h6 class="text-muted mt-4 mb-3"><i class="bi bi-archive"></i> Questions fermées</h6>
        {% for questionId, result in closedResults %}
            <div class="card mb-3">
                <div class="card-header">
                    <small class="text-muted">Résultats</small>
                    <div>{{ result.question.text }}</div>
                </div>
                <div class="card-body">
                    {% set total = result.total %}
                    <small class="text-muted">{{ total }} vote(s)</small>
                    {% for choice in result.question.choices %}
                        {% set count = result.byChoice[choice.id] ?? 0 %}
                        {% set pct = total > 0 ? (count / total * 100)|round : 0 %}
                        <div class="mb-2 mt-1">
                            <div class="d-flex justify-content-between">
                                <span>{{ choice.text }}</span>
                                <span class="text-muted">{{ count }} ({{ pct }}%)</span>
                            </div>
                            <div class="progress" style="height: 12px;">
                                <div class="progress-bar {% if pct == 100 or count == total %}bg-success{% endif %}"
                                     style="width: {{ pct }}%"></div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endfor %}
    {% endif %}
</turbo-frame>
