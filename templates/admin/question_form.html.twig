{% extends 'base.html.twig' %}

{% block title %}{% if question.id %}Modifier{% else %}Nouvelle{% endif %} question{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0">
                    <i class="bi bi-question-circle"></i>
                    {% if question.id %}Modifier la question{% else %}Nouvelle question{% endif %}
                    <small class="text-muted">— {{ session.name }}</small>
                </h4>
            </div>
            <div class="card-body">
                {{ form_start(form) }}

                <div class="mb-4">
                    {{ form_label(form.text) }}
                    {{ form_widget(form.text) }}
                    {{ form_errors(form.text) }}
                </div>

                <h6>Choix de réponse</h6>
                <div data-controller="choices"
                     data-choices-index-value="{{ form.choices|length }}">

                    <div data-choices-container>
                        {% for choiceForm in form.choices %}
                            <div class="choice-row card mb-2">
                                <div class="card-body py-2 px-3">
                                    <div class="d-flex gap-2 align-items-center">
                                        <div class="flex-grow-1">
                                            {{ form_widget(choiceForm.text) }}
                                            {{ form_errors(choiceForm.text) }}
                                        </div>
                                        <div class="form-check d-flex align-items-center gap-1 ms-2">
                                            {{ form_widget(choiceForm.allowFreeText) }}
                                            {{ form_label(choiceForm.allowFreeText) }}
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                data-action="click->choices#removeChoice">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    {% set proto = form.choices.vars.prototype %}
                    {% set protoHtml %}
                    <div class="choice-row card mb-2">
                        <div class="card-body py-2 px-3">
                            <div class="d-flex gap-2 align-items-center">
                                <div class="flex-grow-1">
                                    {{ form_widget(proto.text) }}
                                    {{ form_errors(proto.text) }}
                                </div>
                                <div class="form-check d-flex align-items-center gap-1 ms-2">
                                    {{ form_widget(proto.allowFreeText) }}
                                    {{ form_label(proto.allowFreeText) }}
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-danger"
                                        data-action="click->choices#removeChoice">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    {% endset %}
                    <div data-choices-prototype="{{ protoHtml|e('html_attr') }}" style="display:none"></div>

                    <div class="d-flex gap-2 mb-4">
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                data-action="click->choices#addChoice">
                            <i class="bi bi-plus"></i> Ajouter un choix
                        </button>
                        <button type="button" class="btn btn-outline-danger btn-sm"
                                data-action="click->choices#clearAll">
                            <i class="bi bi-x-circle"></i> Vider les choix
                        </button>
                    </div>
                </div>

                {{ form_errors(form.choices) }}

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i> Enregistrer
                    </button>
                    <a href="{{ path('admin_session_show', {id: session.id}) }}" class="btn btn-outline-secondary">Annuler</a>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
