{% extends 'base.html.twig' %}

{% block title %}Vote - {{ session.name }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4><i class="bi bi-ballot"></i> {{ session.name }}</h4>
            <div class="d-flex align-items-center gap-2">
                <span class="text-muted small"><i class="bi bi-person"></i> {{ participant.name }}</span>
                <form method="post" action="{{ path('participant_leave', {token: participant.token}) }}"
                      onsubmit="return confirm('Quitter la session ? Vous devrez vous réinscrire.')">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-box-arrow-right"></i> Quitter
                    </button>
                </form>
            </div>
        </div>

        {# Main polling frame #}
        <turbo-frame
            id="vote-status"
            src="{{ path('participant_status_frame', {token: participant.token}) }}"
            data-controller="poll"
            data-poll-interval-value="3000">
            {{ include('participant/_status_frame.html.twig') }}
        </turbo-frame>
    </div>
</div>
{% endblock %}
