{% extends 'base.html.twig' %}

{% block title %}Rejoindre - {{ session.name }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-ballot display-3 text-primary"></i>
                <h2 class="mt-3">{{ session.name }}</h2>
                <p class="text-muted">Entrez votre nom pour rejoindre la session de vote.</p>

                {% if error %}
                    <div class="alert alert-danger">{{ error }}</div>
                {% endif %}

                <form method="post" action="{{ path('session_join', {token: session.token}) }}" class="mt-4">
                    <div class="mb-3">
                        <input type="text" name="name" class="form-control form-control-lg text-center"
                               placeholder="Votre nom et prénom"
                               autofocus minlength="2" maxlength="100" required>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="bi bi-box-arrow-in-right"></i> Rejoindre
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
