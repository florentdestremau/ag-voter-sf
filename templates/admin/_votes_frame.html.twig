<turbo-frame id="votes-frame-{{ question.id }}">
    {% set voteCount = question.voteCount %}
    <div class="d-flex align-items-center gap-2 mb-2">
        <div class="progress flex-grow-1" style="height: 20px;">
            {% set pct = totalParticipants > 0 ? (voteCount / totalParticipants * 100)|round : 0 %}
            <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" style="width: {{ pct }}%">
            </div>
        </div>
        <span class="fw-bold text-success">{{ voteCount }}/{{ totalParticipants }}</span>
        <small class="text-muted">votes</small>
    </div>
    {% if byChoice is defined and voteCount > 0 %}
        {% for choice in question.choices %}
            {% set count = byChoice[choice.id] ?? 0 %}
            {% set choicePct = voteCount > 0 ? (count / voteCount * 100)|round : 0 %}
            <div class="mb-1">
                <div class="d-flex justify-content-between small">
                    <span>{{ choice.text }}</span>
                    <span class="text-muted">{{ count }} ({{ choicePct }}%)</span>
                </div>
                <div class="progress" style="height: 6px;">
                    <div class="progress-bar" style="width: {{ choicePct }}%"></div>
                </div>
            </div>
        {% endfor %}
    {% endif %}
</turbo-frame>
