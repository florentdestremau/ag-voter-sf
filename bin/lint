#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

echo "[lint] rector (fix)"
vendor/bin/rector process --no-progress-bar

echo "[lint] php-cs-fixer (fix)"
vendor/bin/php-cs-fixer fix

echo "[lint] phpstan (check)"
vendor/bin/phpstan analyse -c phpstan.neon.dist --no-progress
